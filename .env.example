# Copy this file to .env.local (gitignored) and fill in real values.

# ─── Plaid (Sandbox) ──────────────────────────────────────────────────────
# Free keys at https://dashboard.plaid.com → Team Settings → Keys.
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox

# ─── Supabase ─────────────────────────────────────────────────────────────
# Server-side only. The secret key bypasses RLS — never expose to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx

# ─── Claude (advisor: chat + digests) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Email alerts / digests (optional) ────────────────────────────────────
RESEND_API_KEY=
ALERT_FROM_EMAIL=mehdi@yourdomain.com
ALERT_TO_EMAIL=you@example.com

# ─── Scheduled jobs (optional) ────────────────────────────────────────────
# If set, /api/cron requires Authorization: Bearer <CRON_SECRET>.
# Vercel Cron sends this header automatically when CRON_SECRET is configured.
CRON_SECRET=
