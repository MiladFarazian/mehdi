# Copy this file to .env.local (gitignored) and fill in real values.

# ─── Plaid (Sandbox) ──────────────────────────────────────────────────────
# Free keys at https://dashboard.plaid.com → Team Settings → Keys.
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox

# ─── Supabase ─────────────────────────────────────────────────────────────
# Server-side only. The secret key bypasses RLS — never expose to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx

# ─── Claude advisor (uses your Claude Code / Max subscription) ─────────────
# The advisor calls your local `claude` CLI (run `claude login` once) — no API
# key needed. Only works where the CLI is authenticated (your machine, not a
# cloud deploy). Optional:
CLAUDE_CODE_MODEL=sonnet
# CLAUDE_BIN=/absolute/path/to/claude

# ─── Email alerts / digests (optional) ────────────────────────────────────
RESEND_API_KEY=
ALERT_FROM_EMAIL=mehdi@yourdomain.com
ALERT_TO_EMAIL=you@example.com

# ─── Secret encryption (Plaid token at rest) ──────────────────────────────
# Any high-entropy string. Required before connecting REAL accounts; the Plaid
# access_token is AES-256-GCM encrypted with it. Generate: openssl rand -base64 32
TOKEN_ENC_KEY=

# ─── App password gate ────────────────────────────────────────────────────
# When set, every page + API route requires this password (single-user gate).
# Leave blank to disable the gate (fine for local dev on localhost).
# REQUIRED before exposing the app on the internet.
APP_PASSWORD=

# ─── Scheduled jobs (optional) ────────────────────────────────────────────
# If set, /api/cron requires Authorization: Bearer <CRON_SECRET>.
# Vercel Cron sends this header automatically when CRON_SECRET is configured.
CRON_SECRET=
