# Plaid — create a free account at https://dashboard.plaid.com and copy your
# Sandbox keys (Team Settings → Keys). Sandbox is free and uses fake banks.
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox

# Copy this file to .env.local (which is gitignored) and fill in real values.
